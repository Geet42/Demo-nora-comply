# ============================================================
# Nora Comply — Environment Variables
# Copy this file to .env.local for local dev
# Add all these to Vercel: Project Settings → Environment Variables
# ============================================================

# Supabase (required for real data — get from supabase.com project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App URL (used in email links)
NEXT_PUBLIC_APP_URL=https://demo-nora-comply.vercel.app

# Resend (required for emails — get from resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
DIGEST_TEST_RECIPIENT=you@example.com

# Set to 1 to skip Supabase and show demo data
# NEXT_PUBLIC_DEMO_MODE=1

# Cron secret — set this in Vercel, used to authenticate the cron endpoint
CRON_SECRET=your-random-secret-string-here
